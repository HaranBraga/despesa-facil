# Este arquivo serve de modelo. Copie para .env e preencha os valores reais em produção/local.

# A String de Conexão do seu Banco de Dados (Ex: Supabase, Railway, EasyPanel Postgres)
DATABASE_URL=postgresql://user:password@host:5432/database

# Chave super secreta para gerar tokens de login
JWT_SECRET=preencha_com_uma_senha_forte

# Define o modo para a API desativar logs de debug e checagem de SSL no DB
NODE_ENV=production

# FRONTEND_URL=https://meu-dominio-aqui.com
